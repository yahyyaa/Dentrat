run = "pip install -r backend/requirements.txt -q && cd backend && python app.py"

[nix]
channel = "stable-24_05"

[deployment]
run = ["sh", "-c", "pip install -r backend/requirements.txt -q && cd backend && python app.py"]

[env]
PYTHONUNBUFFERED = "1"

[interpreter]
command = ["python3"]

[packager]
language = "python3"

[packager.features]
packageSearch = true
guessImports = true

[unitTest]
language = "python3"

[languages.python3]
pattern = "**/*.py"

[languages.python3.languageServer]
start = ["pylsp"]
